# Due Diligence Transnacional — environment variables
# Copy this file to .env and fill in your real keys.
# NEVER commit the .env file — it is git-ignored.

# ─── Required ────────────────────────────────────────────────────────────────

# FEC Open Data API
# Get a free key at: https://api.open.fec.gov/developers/
# Without a key: 1,000 req/day. With a free key: 1,000 req/hour.
FEC_API_KEY=your_fec_api_key_here

# OpenCorporates API
# Get a key at: https://opencorporates.com/api_accounts/new
# Free tier: 50 req/day. Journalist plan: free for credentialed outlets.
# Contact: data@opencorporates.com
OPENCORPORATES_API_KEY=your_opencorporates_api_key_here

# ─── Optional ────────────────────────────────────────────────────────────────

# Anthropic API key — only needed if you are using Claude via the API directly,
# outside Claude Code (e.g. running scripts standalone with the SDK).
# Not required when using Claude Code with a Max subscription.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API — optional fallback, not used by the pipeline by default.
# OPENAI_API_KEY=your_openai_api_key_here

# Log verbosity: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO
