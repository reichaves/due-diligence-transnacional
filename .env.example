# Due Diligence Transnacional — variáveis de ambiente
# Copie este arquivo para .env e preencha com suas chaves reais.
# NUNCA comite o arquivo .env.

# FEC Open Data API
# Obter em: https://api.open.fec.gov/developers/
FEC_API_KEY=your_fec_api_key_here

# OpenCorporates API
# Obter em: https://opencorporates.com/api_account/new
OPENCORPORATES_API_KEY=your_opencorporates_api_key_here

# Anthropic API (se usar Claude via API direta, fora do Claude Code)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# (Opcional) OpenAI API — se usar GPT como fallback
# OPENAI_API_KEY=your_openai_api_key_here

# (Opcional) Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
